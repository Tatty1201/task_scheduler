# Chatwork アカウントは accounts.yml に記述する（複数アカウント対応のため）。

# Google Calendar ID (通常は "primary" でメインカレンダー)
GOOGLE_CALENDAR_ID=primary

# タイムゾーン
TIMEZONE=Asia/Tokyo

# 期限なしタスク / date型タスクの既定開始時刻 (HH:MM)
DEFAULT_START_TIME=10:00

# 予定の長さ (分)
DEFAULT_DURATION_MIN=60

# ログレベル (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
